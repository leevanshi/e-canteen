# ==========================================
# E-CANTEEN BACKEND ENV VARS (.env.example)
# ==========================================

# 1. MongoDB Connection
MONGO_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/ecanteen?retryWrites=true&w=majority
DB_NAME=ecanteen

# 2. Security (JWT Auth)
# Generate a strong key using: openssl rand -hex 32 (or similar)
SECRET_KEY=your_super_secret_key_here_change_in_production

# 3. Email Configuration
# For temporary development/testing, Resend is preferred.
# Set RESEND_API_KEY and use onboarding@resend.dev as the sender.
# Later you can switch to a verified sender domain without code changes.
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=onboarding@resend.dev

# Optional SMTP fallback for future deploys or custom domains.
SMTP_USER=your.email@example.com
SMTP_PASSWORD=your_smtp_password_or_app_password
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_STARTTLS=True
SMTP_USE_SSL=False
# SMTP_DEBUG: logs extra info and may echo OTP in API response during testing.
# Does NOT block email delivery (only SMTP_SUPPRESS_SEND blocks sending).
SMTP_DEBUG=False
# SMTP_SUPPRESS_SEND: set True only for local dev without a mail provider.
SMTP_SUPPRESS_SEND=False

# Comma-separated frontend origins allowed by CORS
CORS_ALLOWED_ORIGINS=https://ecanteen-nmims.vercel.app,http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173
ADMIN_NOTIFICATION_EMAILS=admin1@example.com,admin2@example.com
