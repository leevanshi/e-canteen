# ==========================================
# E-CANTEEN BACKEND ENV VARS (.env.example)
# ==========================================

# 1. MongoDB Connection
MONGO_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/ecanteen?retryWrites=true&w=majority
DB_NAME=ecanteen

# 2. Security (JWT Auth)
# Generate a strong key using: openssl rand -hex 32 (or similar)
SECRET_KEY=your_super_secret_key_here_change_in_production

# 3. Email Configuration (FastAPI-Mail)
# Use a Gmail App Password, NOT your regular password!
MAIL_USERNAME=your.actual.email@gmail.com
MAIL_PASSWORD=your_16_char_app_password_no_spaces
MAIL_FROM=your.actual.email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
